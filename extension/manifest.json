{
  "manifest_version": 3,
  "name": "Little Rocky Guardian",
  "version": "1.0.0",
  "description": "Notifies Rocky when you visit distracting sites.",
  "permissions": ["tabs", "webNavigation"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
